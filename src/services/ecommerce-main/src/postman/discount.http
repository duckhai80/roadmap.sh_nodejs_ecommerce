@baseUrl=http://localhost:3056/v1/api/discounts

### Create discount
POST {{baseUrl}}/
Content-Type: application/json
Authorization: {{$dotenv AUTH_TOKEN}}
x-client-id: {{$dotenv X_CLIENT_ID}}
x-api-key: {{$dotenv X_API_KEY}}

{
  "name": "New discount for shop 03",
  "description": "New discount description",
  "type": "percentage",
  "value": 20,
  "code": "SHOP-1155",
  "startDate": "2026-04-04 09:00:00",
  "endDate": "2026-04-20 09:00:00",
  "maxUses": 100,
  "maxUsesPerUser": 1,
  "minOrderValue": 100000,
  "usesCount": 0,
  "usersUsed": [],
  "isActive": true,
  "appliesTo": "specific",
  "appliesToProduct": ["69d7b22815a9235e0ee4006c", "69d79d89b5e2578d08537e90"]
}

